# Application
NODE_ENV=development
API_PORT=3001
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=servicehub

# JWT Authentication
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Mail Configuration (Use Mailtrap for development, SendGrid/SES for production)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM=noreply@servicehub.com
MAIL_FROM_NAME=ServiceHub

# CORS
CORS_ORIGIN=http://localhost:5173
